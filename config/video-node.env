# /etc/default/video-node
# ─────────────────────────────────────────────────────────────────────────────
# Runtime configuration for p2p-stream service.
# Edit this file to change stream parameters without recompiling.
#
# Priority: U-Boot env > this file > compiled defaults
# ─────────────────────────────────────────────────────────────────────────────

# Network role: ap | sta
#   ap  — This device creates the Wi-Fi Direct / hotspot link (display side).
#          Runs p2p-init, waits for camera device to associate.
#   sta — This device joins the Wi-Fi link (camera side).
#          Waits for AP link, then connects and starts streaming.
P2P_NET_ROLE=ap

# Stream role: sender | receiver
#   sender   — Captures from camera, encodes, sends UDP.
#   receiver — Receives UDP, decodes, outputs to display.
#
# Typical pairing:
#   Camera device  : P2P_NET_ROLE=sta  P2P_STREAM_ROLE=sender
#   Display device : P2P_NET_ROLE=ap   P2P_STREAM_ROLE=receiver
P2P_STREAM_ROLE=receiver

# Device profile: nxp | jetson | rpi4 | pc
P2P_DEVICE=nxp

# Codec: h265 | h264
P2P_CODEC=h264

# Sink (receiver only): hdmi | display | file | rtsp
P2P_SINK=hdmi

# Trigger mode: auto | manual | gpio
#   auto   — stream starts automatically when Wi-Fi link is up
#   manual — wait for: echo start > /run/p2p-stream.cmd
#   gpio   — wait for GPIO rising edge (sender only)
P2P_TRIGGER=auto

# Video parameters
P2P_WIDTH=1280
P2P_HEIGHT=720
P2P_FPS=120
P2P_BITRATE=6000000

# File output path (only used when P2P_SINK=file)
# P2P_OUTPUT=/var/p2p-recordings/stream.mp4